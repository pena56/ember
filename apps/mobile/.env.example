# Convex deployment URL — required for sync, claim, and anonymous sign-in.
# Copy this file to .env.local and fill in your dev deployment URL.
# Find it at dashboard.convex.dev or via `npx convex dev` output.
# Expo only exposes EXPO_PUBLIC_-prefixed variables to the client bundle.
# Restart Metro with cache cleared after editing: `expo start --clear`
EXPO_PUBLIC_CONVEX_URL=https://<your-deployment>.convex.cloud
