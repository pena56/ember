{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/tracker-issue-drift.sh\"",
            "timeout": 15,
            "statusMessage": "Checking tracker vs GitHub issues…"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/doc-sync.sh\"",
            "timeout": 10,
            "statusMessage": "Checking doc sync…"
          }
        ]
      }
    ]
  }
}
